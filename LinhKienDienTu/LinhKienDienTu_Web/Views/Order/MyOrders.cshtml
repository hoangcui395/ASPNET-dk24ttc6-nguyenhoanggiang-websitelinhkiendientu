@model List<LinhKienDienTu_Web.Models.Order>
@using System.Globalization
@{
    ViewData["Title"] = "Lịch sử đơn hàng";
    var culture = new CultureInfo("vi-VN");
}

<style>
    .order-history-hero {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
        padding: 3rem 0 2rem;
        margin-bottom: 2.5rem;
    }
    .order-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        transition: transform 0.2s, box-shadow 0.2s;
        overflow: hidden;
    }
    .order-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    }
    .order-card-header {
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
        padding: 1rem 1.25rem;
    }
    .badge-status {
        font-size: 0.8rem;
        padding: 0.4em 0.9em;
        border-radius: 50rem;
        font-weight: 600;
    }
    .badge-pending   { background: #fff7ed; color: #c2410c; border: 1px solid #fed7aa; }
    .badge-picking   { background: #fef9c3; color: #854d0e; border: 1px solid #fef08a; }
    .badge-shipping  { background: #e0f2fe; color: #0369a1; border: 1px solid #bae6fd; }
    .badge-success   { background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0; }
    .badge-cancelled { background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca; }

    .btn-detail {
        background: #0056b3;
        color: white;
        border: none;
        border-radius: 50rem;
        padding: 0.4rem 1.1rem;
        font-size: 0.85rem;
        font-weight: 600;
        transition: background 0.2s;
    }
    .btn-detail:hover { background: #55aa00; color: white; }
    .btn-reorder {
        background: transparent;
        color: #0056b3;
        border: 1.5px solid #0056b3;
        border-radius: 50rem;
        padding: 0.4rem 1.1rem;
        font-size: 0.85rem;
        font-weight: 600;
        transition: all 0.2s;
    }
    .btn-reorder:hover { background: #0056b3; color: white; }
    .btn-cancel-order {
        background: transparent;
        color: #dc2626;
        border: 1.5px solid #dc2626;
        border-radius: 50rem;
        padding: 0.4rem 1.1rem;
        font-size: 0.85rem;
        font-weight: 600;
        transition: all 0.2s;
    }
    .btn-cancel-order:hover { background: #dc2626; color: white; }

    .track-line {
        display: flex;
        justify-content: space-between;
        padding: 0.5rem 0;
        position: relative;
    }
    .track-dot { width: 12px; height: 12px; border-radius: 50%; background: #e2e8f0; z-index: 2; }
    .track-dot.active { background: #0056b3; box-shadow: 0 0 0 3px rgba(102,204,0,0.2); }
    .track-progress {
        position: absolute;
        top: 14px;
        left: 0;
        right: 0;
        height: 2px;
        background: #e2e8f0;
        z-index: 1;
    }
    .track-progress-fill { height: 100%; background: #0056b3; transition: width 0.3s; }

    /* Cancel modal */
    .cancel-reason-option {
        cursor: pointer;
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        padding: 0.75rem 1rem;
        margin-bottom: 0.5rem;
        transition: all 0.15s;
    }
    .cancel-reason-option:has(input:checked) {
        border-color: #dc2626;
        background: #fef2f2;
    }
    .cancel-reason-option input { margin-right: 0.5rem; }
</style>

<!-- Hero -->
<div class="order-history-hero">
    <div class="container">
        <div class="d-flex align-items-center gap-3">
            <div style="background: rgba(102,204,0,0.15); border-radius: 14px; padding: 0.9rem 1.1rem;">
                <i class="fas fa-receipt fa-xl" style="color: #0056b3;"></i>
            </div>
            <div>
                <h1 class="fw-bold text-white mb-1">Hành trình đơn hàng</h1>
                <p class="text-white-50 mb-0">Theo dõi trạng thái giao hàng, xem chi tiết và mua lại món ngon chỉ với 1 click.</p>
            </div>
        </div>
    </div>
</div>

<div class="container pb-5">

    @* Thông báo giỏ hàng/thanh toán *@
    @if (TempData["CartMessage"] is string cartMsg)
    {
        <div class="alert alert-info rounded-4 border-0 mb-4 d-flex align-items-center gap-3">
            <i class="fas fa-cart-plus fa-lg"></i>
            <span class="fw-semibold">@cartMsg</span>
        </div>
    }

    @* Thông báo đặt hàng thành công *@
    @if (ViewBag.CheckoutSuccess is string successMsg)
    {
        <div class="alert rounded-4 border-0 mb-4 d-flex align-items-center gap-3"
             style="background: #f0fdf4; border-left: 4px solid #16a34a !important; border-radius: 12px !important;">
            <i class="fas fa-circle-check fa-lg" style="color:#16a34a;"></i>
            <span class="fw-semibold" style="color:#15803d;">@successMsg</span>
        </div>
    }

    @* Thông báo lỗi tìm kiếm đơn hàng *@
    @if (TempData["MyOrdersError"] is string errorMsg)
    {
        <div class="alert rounded-4 border-0 mb-4 d-flex align-items-center gap-3"
             style="background: #fef2f2; border-left: 4px solid #dc2626 !important;">
            <i class="fas fa-circle-exclamation fa-lg" style="color:#dc2626;"></i>
            <span class="fw-semibold" style="color:#b91c1c;">@errorMsg</span>
        </div>
    }

    @* Thông báo hủy thành công *@
    @if (TempData["CancelSuccess"] is string cancelOk)
    {
        <div class="alert rounded-4 border-0 mb-4 d-flex align-items-center gap-3"
             style="background: #eff6ff; border-left: 4px solid #2563eb !important;">
            <i class="fas fa-info-circle fa-lg" style="color:#2563eb;"></i>
            <span class="fw-semibold" style="color:#1d4ed8;">@cancelOk</span>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="mb-4">
                <i class="fas fa-box-open fa-4x" style="color:#cbd5e1;"></i>
            </div>
            <h3 class="fw-bold text-dark mb-2">Chưa có đơn hàng nào</h3>
            <p class="text-muted mb-4">Hãy thêm sản phẩm vào giỏ hàng và đặt hàng để bắt đầu!</p>
            <a asp-controller="Home" asp-action="Index" class="btn rounded-pill px-5 py-2 fw-bold text-white" style="background:#0056b3;">
                <i class="fas fa-shopping-bag me-2"></i>Xem sản phẩm
            </a>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var order in Model)
            {
                var canCancel = order.Trang_Thai_Don_Hang == "Chờ xác nhận";

                string badgeClass = order.Trang_Thai_Don_Hang switch {
                    "Đang lấy hàng" => "badge-picking",
                    "Đang giao"     => "badge-shipping",
                    "Thành công"    => "badge-success",
                    "Đã hủy"        => "badge-cancelled",
                    _               => "badge-pending"
                };

                // Tính toán ProgressBar
                int progress = order.Trang_Thai_Don_Hang switch {
                    "Chờ xác nhận" => 5,
                    "Đang lấy hàng" => 35,
                    "Đang giao" => 70,
                    "Thành công" => 100,
                    _ => 0
                };

                <div class="order-card">
                    <div class="order-card-header d-flex flex-wrap align-items-center justify-content-between gap-2">
                        <div class="d-flex align-items-center gap-3">
                            <div>
                                <div class="fw-bold" style="font-size:1.05rem;">#@order.Order_ID</div>
                                <div class="text-muted small">@order.Ngay_Dat.ToString("dd/MM/yyyy HH:mm")</div>
                            </div>
                            <span class="badge-status @badgeClass">@order.Trang_Thai_Don_Hang</span>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="text-end d-none d-md-block">
                                @{
                                    var tongGiaGoc = order.OrderDetails.Sum(d => (d.Product?.Gia_Goc > d.Gia_Ban ? d.Product.Gia_Goc : d.Gia_Ban) * d.So_Luong);
                                    var tongTietKiem = order.OrderDetails.Sum(d => (d.Product?.Gia_Goc > d.Gia_Ban ? d.Product.Gia_Goc - d.Gia_Ban : 0) * d.So_Luong) + order.Tien_Tiet_Kiem_Voucher;
                                    var displayTotal = tongGiaGoc - tongTietKiem + order.Phi_Ship;
                                }
                                @if (tongTietKiem > 0)
                                {
                                    <div class="text-muted small" style="text-decoration: line-through;">@tongGiaGoc.ToString("C0", culture)</div>
                                    <div class="text-success small fw-semibold" style="font-size: 0.75rem;">Tiết kiệm @tongTietKiem.ToString("C0", culture)</div>
                                }
                            </div>
                            <div class="text-end">
                                <span class="small text-muted d-block" style="font-size: 0.7rem;">Tổng thanh toán</span>
                                <strong class="text-success fs-5">@displayTotal.ToString("C0", culture)</strong>
                            </div>
                        </div>
                    </div>
                    
                    <div class="px-4 py-3 bg-light-subtle">
                        @if (order.Trang_Thai_Don_Hang != "Đã hủy")
                        {
                            <div class="track-line mx-2">
                                <div class="track-progress"><div class="track-progress-fill" style="width: @progress%"></div></div>
                                <div class="track-dot @(progress >= 5 ? "active" : "")" title="Chờ xác nhận"></div>
                                <div class="track-dot @(progress >= 35 ? "active" : "")" title="Đang lấy hàng"></div>
                                <div class="track-dot @(progress >= 70 ? "active" : "")" title="Đang giao"></div>
                                <div class="track-dot @(progress >= 100 ? "active" : "")" title="Thành công"></div>
                            </div>
                            <div class="d-flex justify-content-between small text-muted px-1 mt-1">
                                <span>Chờ xác nhận</span>
                                <span>Cửa hàng lấy món</span>
                                <span>Đang giao</span>
                                <span>Giao thành công</span>
                            </div>
                        }
                    </div>

                    <div class="px-3 py-3 d-flex flex-wrap align-items-center justify-content-between gap-2">
                        <div>
                            <div class="small text-muted">
                                <i class="fas fa-location-dot me-1"></i>@order.Dia_Chi_Giao_Hang
                                @if (order.Phi_Ship > 0) { <span class="ms-2 badge bg-light text-dark fw-normal border">Phí ship: @order.Phi_Ship.ToString("N0")đ</span> }
                            </div>
                            @if (order.Trang_Thai_Don_Hang == "Đã hủy" && !string.IsNullOrWhiteSpace(order.Ly_Do_Huy))
                            {
                                <div class="small text-danger mt-1"><i class="fas fa-ban me-1"></i>Lý do hủy: @order.Ly_Do_Huy</div>
                            }
                        </div>
                        <div class="d-flex gap-2">
                            <form asp-controller="Cart" asp-action="Reorder" asp-route-orderId="@order.Order_ID" method="post">
                                <button type="submit" class="btn-reorder">
                                    <i class="fas fa-rotate-left me-1"></i>Mua lại
                                </button>
                            </form>
                            <a asp-controller="Order" asp-action="Detail" asp-route-id="@order.Order_ID"
                               class="btn-detail">
                                <i class="fas fa-eye me-1"></i>Chi tiết
                            </a>
                            @if (canCancel)
                            {
                                <button type="button" class="btn-cancel-order"
                                        data-bs-toggle="modal"
                                        data-bs-target="#cancelModal-@order.Order_ID">
                                    <i class="fas fa-xmark me-1"></i>Hủy đơn
                                </button>
                            }
                        </div>
                    </div>
                </div>

                @* Modal Hủy đơn hàng *@
                @if (canCancel)
                {
                    <div class="modal fade" id="cancelModal-@order.Order_ID" tabindex="-1">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content rounded-4 border-0 shadow">
                                <div class="modal-header border-0 pb-0">
                                    <h5 class="modal-title fw-bold">
                                        <i class="fas fa-triangle-exclamation text-warning me-2"></i>
                                        Xác nhận hủy đơn #@order.Order_ID
                                    </h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <form asp-controller="Order" asp-action="Cancel" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="orderId" value="@order.Order_ID" />
                                    <div class="modal-body pt-3">
                                        <p class="text-muted small mb-3">Khi hủy, tồn kho sẽ được hoàn lại tự động. Vui lòng chọn lý do:</p>
                                        <div>
                                            <label class="cancel-reason-option d-block">
                                                <input type="radio" name="lyDoHuy" value="Tôi muốn thay đổi địa chỉ giao hàng" required />
                                                Tôi muốn thay đổi địa chỉ giao hàng
                                            </label>
                                            <label class="cancel-reason-option d-block">
                                                <input type="radio" name="lyDoHuy" value="Tôi muốn thay đổi sản phẩm trong đơn" />
                                                Tôi muốn thay đổi sản phẩm trong đơn
                                            </label>
                                            <label class="cancel-reason-option d-block">
                                                <input type="radio" name="lyDoHuy" value="Tôi tìm thấy giá tốt hơn ở nơi khác" />
                                                Tôi tìm thấy giá tốt hơn ở nơi khác
                                            </label>
                                            <label class="cancel-reason-option d-block">
                                                <input type="radio" name="lyDoHuy" value="Tôi đặt nhầm sản phẩm" />
                                                Tôi đặt nhầm sản phẩm
                                            </label>
                                            <label class="cancel-reason-option d-block">
                                                <input type="radio" name="lyDoHuy" value="Lý do khác" />
                                                Lý do khác
                                            </label>
                                        </div>
                                    </div>
                                    <div class="modal-footer border-0 pt-0 d-flex gap-2">
                                        <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Quay lại</button>
                                        <button type="submit" class="btn btn-danger rounded-pill px-4 fw-semibold">
                                            <i class="fas fa-ban me-1"></i>Xác nhận hủy
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    }
</div>
