@model LinhKienDienTu_Web.Models.Order
@using System.Globalization
@{
    ViewData["Title"] = $"Chi tiết đơn hàng #{Model.Order_ID}";
    var culture = new CultureInfo("vi-VN");
    var canCancel = Model.Trang_Thai_Don_Hang != "Hoàn thành" && Model.Trang_Thai_Don_Hang != "Đang giao hàng" && Model.Trang_Thai_Don_Hang != "Đã hủy";
    string badgeClass = Model.Trang_Thai_Don_Hang switch {
        "Đã xác nhận"    => "badge-paid",
        "Đang giao hàng" => "badge-delivered",
        "Hoàn thành"     => "badge-delivered",
        "Đã hủy"         => "badge-cancelled",
        _                => "badge-pending"
    };
}

<style>
    .detail-hero {
        background: linear-gradient(135deg, #0f2027 0%, #203a43 50%, #2c5364 100%);
        padding: 2.5rem 0 2rem;
        margin-bottom: 2rem;
    }
    .info-card { border: none; border-radius: 16px; box-shadow: 0 2px 12px rgba(0,0,0,0.07); }
    .badge-status { font-size: 0.82rem; padding: 0.45em 1em; border-radius: 50rem; font-weight: 700; }
    .badge-pending   { background: #fff7ed; color: #c2410c; border: 1px solid #fed7aa; }
    .badge-paid      { background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0; }
    .badge-cancelled { background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca; }
    .badge-delivered { background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; }
    .product-row { border-bottom: 1px solid #f1f5f9; padding: 0.9rem 0; }
    .product-row:last-child { border-bottom: none; }
    .product-img { width: 56px; height: 56px; object-fit: cover; border-radius: 10px; }
    .total-row { background: #f8fafc; border-radius: 12px; padding: 1rem 1.25rem; }
    .cancel-reason-option {
        cursor: pointer;
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        padding: 0.75rem 1rem;
        margin-bottom: 0.5rem;
        transition: all 0.15s;
    }
    .cancel-reason-option:has(input:checked) {
        border-color: #dc2626;
        background: #fef2f2;
    }
</style>

<!-- Hero -->
<div class="detail-hero">
    <div class="container">
        <div class="d-flex align-items-center gap-2 text-white-50 small mb-2">
            <a asp-controller="Order" asp-action="MyOrders" class="text-white-50 text-decoration-none">
                <i class="fas fa-arrow-left me-1"></i>Lịch sử đơn hàng
            </a>
            <span>/</span>
            <span>Đơn hàng #@Model.Order_ID</span>
        </div>
        <div class="d-flex align-items-center gap-3">
            <div>
                <h1 class="fw-bold text-white mb-1">Đơn hàng #@Model.Order_ID</h1>
                <p class="text-white-50 mb-0">Đặt lúc @Model.Ngay_Dat.ToString("HH:mm - dd/MM/yyyy")</p>
            </div>
            <span class="badge-status @badgeClass ms-2">@Model.Trang_Thai_Don_Hang</span>
        </div>
    </div>
</div>

<div class="container pb-5">

    @* Thông báo lỗi hủy *@
    @if (TempData["CancelError"] is string cancelErr)
    {
        <div class="alert alert-danger rounded-4 mb-4">
            <i class="fas fa-circle-xmark me-2"></i>@cancelErr
        </div>
    }

    <div class="row g-4">

        <!-- Bên trái: Danh sách sản phẩm -->
        <div class="col-lg-8">
            <div class="info-card bg-white p-4 mb-4">
                <h5 class="fw-bold mb-3"><i class="fas fa-box me-2 text-success"></i>Sản phẩm đã đặt</h5>

                @foreach (var detail in Model.OrderDetails)
                {
                    <div class="product-row d-flex align-items-center gap-3">
                        <img src="@(string.IsNullOrWhiteSpace(detail.Product?.Hinh_Anh) ? "/images/placeholder.png" : detail.Product.Hinh_Anh)"
                             alt="@detail.Product?.Ten_San_Pham"
                             class="product-img" />
                        <div class="flex-grow-1">
                            <div class="fw-semibold">@(detail.Product?.Ten_San_Pham ?? $"Sản phẩm #{detail.Product_ID}")</div>
                            <div class="text-muted small">
                                @if (detail.Product?.Gia_Goc > detail.Gia_Ban)
                                {
                                    <del class="text-secondary opacity-50 me-1">@detail.Product.Gia_Goc.ToString("C0", culture)</del>
                                }
                                @detail.Gia_Ban.ToString("C0", culture) &times; @detail.So_Luong
                            </div>
                        </div>
                        <div class="fw-bold text-success">
                            @((detail.Gia_Ban * detail.So_Luong).ToString("C0", culture))
                        </div>
                    </div>
                }

                @{
                    var tongGiaGoc = Model.OrderDetails.Sum(d => (d.Product?.Gia_Goc > d.Gia_Ban ? d.Product.Gia_Goc : d.Gia_Ban) * d.So_Luong);
                    var tongTietKiem = Model.OrderDetails.Sum(d => (d.Product?.Gia_Goc > d.Gia_Ban ? d.Product.Gia_Goc - d.Gia_Ban : 0) * d.So_Luong);
                    var tongThanhToan = tongGiaGoc - tongTietKiem - Model.Tien_Tiet_Kiem_Voucher + Model.Phi_Ship;
                }

                <div class="total-row mt-3">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="text-muted small">Tổng tiền hàng gốc</span>
                        <strong class="text-muted">@tongGiaGoc.ToString("C0", culture)</strong>
                    </div>
                    
                    @if (tongTietKiem > 0)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="text-success small"><i class="fas fa-tags me-1"></i>Tiết kiệm từ Khuyến mãi</span>
                            <span class="text-success">-@tongTietKiem.ToString("C0", culture)</span>
                        </div>
                    }

                    @if (Model.Tien_Tiet_Kiem_Voucher > 0)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="text-success small"><i class="fas fa-ticket-alt me-1"></i>Voucher giảm giá</span>
                            <span class="text-success">@("-" + Model.Tien_Tiet_Kiem_Voucher.ToString("C0", culture))</span>
                        </div>
                    }

                    <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
                        <span class="text-muted small">Phí vận chuyển</span>
                        <strong class="text-muted">@Model.Phi_Ship.ToString("C0", culture)</strong>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-2 pb-1 border-top pt-2">
                        <span class="fw-bold">Tổng thanh toán cuối cùng</span>
                        <strong class="text-danger fs-4 fw-bold">@tongThanhToan.ToString("C0", culture)</strong>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bên phải: Thông tin đơn + Hành động -->
        <div class="col-lg-4">
            <div class="info-card bg-white p-4 mb-4">
                <h5 class="fw-bold mb-3"><i class="fas fa-info-circle me-2 text-success"></i>Thông tin đơn hàng</h5>
                <dl class="mb-0" style="line-height: 2;">
                    <dt class="text-muted small fw-normal">Trạng thái</dt>
                    <dd><span class="badge-status @badgeClass">@Model.Trang_Thai_Don_Hang</span></dd>

                    <dt class="text-muted small fw-normal mt-2">Địa chỉ giao hàng</dt>
                    <dd class="fw-semibold">@Model.Dia_Chi_Giao_Hang</dd>

                    @if (!string.IsNullOrWhiteSpace(Model.Ghi_Chu))
                    {
                        <dt class="text-muted small fw-normal mt-2">Ghi chú</dt>
                        <dd>@Model.Ghi_Chu</dd>
                    }

                    @if (Model.Trang_Thai_Don_Hang == "Đã hủy" && !string.IsNullOrWhiteSpace(Model.Ly_Do_Huy))
                    {
                        <dt class="text-muted small fw-normal mt-2">Lý do hủy</dt>
                        <dd class="text-danger">@Model.Ly_Do_Huy</dd>
                    }
                </dl>
            </div>

            <!-- Nút hành động -->
            <div class="d-flex flex-column gap-2">
                <a asp-controller="Order" asp-action="MyOrders"
                   class="btn btn-outline-secondary rounded-pill w-100">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại danh sách
                </a>

                @if (canCancel)
                {
                    <button type="button" class="btn btn-outline-danger rounded-pill w-100 fw-semibold"
                            data-bs-toggle="modal" data-bs-target="#cancelModal">
                        <i class="fas fa-ban me-2"></i>Hủy đơn hàng này
                    </button>
                }
            </div>
        </div>

    </div>
</div>

@* Modal Hủy đơn hàng *@
@if (canCancel)
{
    <div class="modal fade" id="cancelModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4 border-0 shadow">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">
                        <i class="fas fa-triangle-exclamation text-warning me-2"></i>
                        Xác nhận hủy đơn #@Model.Order_ID
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form asp-controller="Order" asp-action="Cancel" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId" value="@Model.Order_ID" />
                    <div class="modal-body pt-3">
                        <p class="text-muted small mb-3">
                            Khi hủy, tồn kho sẽ được hoàn lại tự động. Vui lòng chọn lý do:
                        </p>
                        <div>
                            <label class="cancel-reason-option d-block">
                                <input type="radio" name="lyDoHuy" value="Tôi muốn thay đổi địa chỉ giao hàng" required />
                                Tôi muốn thay đổi địa chỉ giao hàng
                            </label>
                            <label class="cancel-reason-option d-block">
                                <input type="radio" name="lyDoHuy" value="Tôi muốn thay đổi sản phẩm trong đơn" />
                                Tôi muốn thay đổi sản phẩm trong đơn
                            </label>
                            <label class="cancel-reason-option d-block">
                                <input type="radio" name="lyDoHuy" value="Tôi tìm thấy giá tốt hơn ở nơi khác" />
                                Tôi tìm thấy giá tốt hơn ở nơi khác
                            </label>
                            <label class="cancel-reason-option d-block">
                                <input type="radio" name="lyDoHuy" value="Tôi đặt nhầm sản phẩm" />
                                Tôi đặt nhầm sản phẩm
                            </label>
                            <label class="cancel-reason-option d-block">
                                <input type="radio" name="lyDoHuy" value="Lý do khác" />
                                Lý do khác
                            </label>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0 d-flex gap-2">
                        <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Quay lại</button>
                        <button type="submit" class="btn btn-danger rounded-pill px-4 fw-semibold">
                            <i class="fas fa-ban me-1"></i>Xác nhận hủy
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
