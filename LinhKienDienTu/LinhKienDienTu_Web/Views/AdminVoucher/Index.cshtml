@model IEnumerable<LinhKienDienTu_Web.Models.Voucher>
@{
    ViewData["Title"] = "Quản lý Voucher";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="fas fa-ticket-alt me-2 text-primary"></i>Quản lý Voucher</h2>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-plus me-2"></i>Tạo mã mới
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm border-0 mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">Mã Code</th>
                        <th>Loại giảm</th>
                        <th>Giá trị</th>
                        <th>Đơn tối thiểu</th>
                        <th>Lượt dùng</th>
                        <th>Hiệu lực</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="badge bg-light text-dark border px-3 py-2 font-monospace">@item.Ma_Code</span>
                            </td>
                            <td>@(item.Loai_Giam_Gia == "PERCENT" ? "Phần trăm (%)" : "Trừ tiền (đ)")</td>
                            <td class="fw-bold">
                                @(item.Loai_Giam_Gia == "PERCENT" ? item.Gia_Tri_Giam + "%" : item.Gia_Tri_Giam.ToString("N0") + "đ")
                            </td>
                            <td class="text-muted small">@item.Don_Toi_Thieu.ToString("N0")đ</td>
                            <td>
                                <div class="progress" style="height: 6px; width: 80px;">
                                    @{
                                        var percent = item.So_Luong_Gioi_Han > 0 ? (item.So_Luong_Da_Dung * 100 / item.So_Luong_Gioi_Han) : 0;
                                    }
                                    <div class="progress-bar bg-success" style="width: @percent%"></div>
                                </div>
                                <span class="small font-monospace">@item.So_Luong_Da_Dung/@item.So_Luong_Gioi_Han</span>
                            </td>
                            <td class="small">
                                <div>@item.Ngay_Bat_Dau.ToString("dd/MM/yyyy")</div>
                                <div class="text-muted">@item.Ngay_Het_Han.ToString("dd/MM/yyyy")</div>
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill px-3">Hết hạn/Tắt</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="Edit" asp-route-id="@item.Voucher_ID" class="btn btn-sm btn-outline-primary rounded-circle border-0">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <button onclick="deleteVoucher(@item.Voucher_ID)" class="btn btn-sm btn-outline-danger rounded-circle border-0 ms-2">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deleteVoucher(id) {
            if (confirm("Bạn có chắc chắn muốn xóa mã giảm giá này?")) {
                $.post("/AdminVoucher/Delete/" + id, function (res) {
                    if (res.success) window.location.reload();
                    else alert("Lỗi khi xóa!");
                });
            }
        }
    </script>
}
