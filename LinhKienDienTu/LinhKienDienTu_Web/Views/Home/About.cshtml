@{
    ViewData["Title"] = "Về Linh Kiện Điện Tử HG";
}

<style>
    .about-hero {
        background: linear-gradient(135deg, rgba(15,32,39,0.5) 0%, rgba(32,58,67,0.5) 50%, rgba(44,83,100,0.5) 100%), url('/sgf_family_meal_hero_1775707978747.png') center/cover;
        color: white;
        padding: 8rem 0;
        border-radius: 2rem;
        margin-bottom: 4rem;
        box-shadow: 0 20px 40px rgba(0,0,0,0.2);
    }
    .feature-icon {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: #f0fdf4;
        color: #15803d;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        margin: 0 auto 1.5rem;
    }
</style>

<div class="container py-4">
    <div class="about-hero text-center">
        <h1 class="display-3 fw-bold mb-3">SÀI GÒN FOOD</h1>
        <p class="lead mb-0 text-white fw-bold" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.5);">Đồng Hành Cùng Bữa Ăn Gia Đình Việt</p>
    </div>

    <div class="row mb-5 align-items-center">
        <div class="col-md-6 mb-4 mb-md-0">
            <h2 class="fw-bold mb-3" style="color: #0056b3;">Câu chuyện của chúng tôi</h2>
            <p class="text-muted" style="line-height: 1.8; font-size: 1.1rem;">
                Được thành lập từ năm 2003, Linh Kiện Điện Tử HG đã không ngừng nỗ lực để mang đến những sản phẩm tiện lợi, an toàn và chất lượng cao nhất cho gia đình Việt. 
                Với hơn 2 thập kỷ hình thành và phát triển, chúng tôi tự hào là đơn vị tiên phong trong lĩnh vực sản xuất thực phẩm chế biến sẵn và hải sản đông lạnh.
            </p>
            <p class="text-muted" style="line-height: 1.8;">
                Chúng tôi không chỉ bán thực phẩm, chúng tôi trao gửi sự an tâm, tiện lợi và những giá trị dinh dưỡng cao nhất trong mỗi bữa ăn.
            </p>
        </div>
        <div class="col-md-6 text-center">
            <img src="/sgf_factory_hero_1775707960016.png" alt="Linh Kiện Điện Tử HG Factory" class="img-fluid rounded-4 shadow-lg" style="max-height: 400px; width: 100%; object-fit: cover;" />
        </div>
    </div>

    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="card h-100 border-0 p-4 shadow-sm rounded-4">
                <div class="feature-icon"><i class="fas fa-leaf"></i></div>
                <h5 class="fw-bold">Nguyên liệu tươi sạch</h5>
                <p class="text-muted small">Cam kết sử dụng nguyên liệu đạt chuẩn, quy trình kiểm định nghiêm ngặt từ nông trại tới bàn ăn.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 p-4 shadow-sm rounded-4">
                <div class="feature-icon"><i class="fas fa-microchip"></i></div>
                <h5 class="fw-bold">Công nghệ hiện đại</h5>
                <p class="text-muted small">Dây chuyền sản xuất tiên tiến, đạt chuẩn quốc tế ISO và HACCP, đảm bảo an toàn tuyệt đối.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 p-4 shadow-sm rounded-4">
                <div class="feature-icon"><i class="fas fa-heart"></i></div>
                <h5 class="fw-bold">Tận tâm phục vụ</h5>
                <p class="text-muted small">Khách hàng là trung tâm của mọi hoạt động, Linh Kiện Điện Tử HG luôn nỗ lực vì sự hài lòng cao nhất.</p>
            </div>
        </div>
    </div>
</div>
