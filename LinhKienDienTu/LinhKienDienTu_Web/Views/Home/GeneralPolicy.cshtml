@{
    ViewData["Title"] = "Điều khoản sử dụng (Chính sách chung)";
}

<div class="container py-5">
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h1 class="fw-bold mb-3">Điều Khoản <span style="color: #0056b3;">Sử Dụng</span></h1>
            <p class="text-muted">Cập nhật lần cuối: 15/04/2026</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5">
                
                <h4 class="fw-bold text-success mb-3">1. Quy định về tài khoản</h4>
                <p class="text-muted" style="line-height: 1.8;">
                    Khách hàng đăng ký tài khoản trên website Linh Kiện Điện Tử HG phải cung cấp thông tin chính xác. Bạn có trách nhiệm bảo mật mật khẩu và sẽ chịu hoàn toàn trách nhiệm đối với tất cả các hoạt động xảy ra dưới tài khoản của mình. Linh Kiện Điện Tử HG có quyền từ chối cung cấp dịch vụ, đóng tài khoản hoặc hủy đơn hàng theo quyết định riêng.
                </p>

                <hr class="my-4">

                <h4 class="fw-bold text-success mb-3">2. Quy định đặt hàng và thanh toán</h4>
                <p class="text-muted" style="line-height: 1.8;">
                    Thông tin hiển thị trên website là lời mời giao dịch, không phải là đề nghị giao kết hợp đồng. Đơn hàng của bạn sẽ chỉ được coi là hợp lệ khi được hệ thống Linh Kiện Điện Tử HG xác nhận qua Email hoặc Trạng thái đơn hàng. Nếu có sai sót về giá trên hệ thống, chúng tôi có quyền hủy đơn hàng và hoàn tiền lại nguyên vẹn cho Quý khách.
                </p>

                <hr class="my-4">

                <h4 class="fw-bold text-success mb-3">3. Quy định đổi trả/hoàn tiền</h4>
                <p class="text-muted" style="line-height: 1.8;">
                    Sản phẩm tại Linh Kiện Điện Tử HG đa phần là thực phẩm chế biến và đóng gói. Đối với sản phẩm đông lạnh/đông mát, khách hàng vui lòng kiểm tra ngay khi nhận hàng. Nếu có lỗi từ NSX (thủng bao bì, hỏng, hôi mùi lạ), chúng tôi sẽ đổi 1:1 trong vòng 24H xử lý. Đối với các sản phẩm bảo quản khô, đổi trả trong vòng 3 ngày kể từ lúc nhận hàng chưa khui tem seal.
                </p>

            </div>
        </div>
    </div>
</div>
