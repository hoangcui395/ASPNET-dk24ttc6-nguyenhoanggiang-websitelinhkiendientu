@model Product
@using System.Globalization

@{
    var culture = new CultureInfo("vi-VN");
    var now = DateTime.Now;
    bool hasActivePromotion = Model.Promotion != null &&
        Model.Promotion.Ngay_Bat_Dau <= now &&
        Model.Promotion.Ngay_Ket_Thuc >= now;

    decimal totalDiscountPercent = hasActivePromotion ? Model.Promotion.Phan_Tram_Giam : Model.Phan_Tram_Giam;
    totalDiscountPercent = Math.Min(totalDiscountPercent, 100m);

    decimal finalPrice = Model.Gia_Goc * (1 - totalDiscountPercent / 100);
    bool isTphcmOnly = Model.IsTphcmOnly;

    int effectiveStock = Model.So_Luong_Ton;
    if (Model.IsCombo && Model.ComboDetails != null && Model.ComboDetails.Any())
    {
        effectiveStock = int.MaxValue;
        foreach (var item in Model.ComboDetails)
        {
            if (item.ComponentProduct != null)
            {
                int possible = item.ComponentProduct.So_Luong_Ton / item.So_Luong_Thanh_Phan;
                if (possible < effectiveStock) effectiveStock = possible;
            }
        }
        if (effectiveStock == int.MaxValue) effectiveStock = 0;
    }
    bool isOutOfStock = effectiveStock <= 0;
}

<div class="product-card d-flex flex-column h-100 @(isOutOfStock ? "out-of-stock" : "")">
    <a href="/Home/Details/@Model.Product_ID" class="text-decoration-none text-dark d-flex flex-column flex-grow-1">
        <div class="product-card-img-wrapper">
            @if (totalDiscountPercent > 0)
            {
                <div class="badge-discount">-@totalDiscountPercent%</div>
            }
            @if (isTphcmOnly)
            {
                <div class="badge-location" title="Chỉ giao tại TP.HCM">
                    <i class="fas fa-map-marker-alt me-1"></i> TP.HCM
                </div>
            }
            @if (isOutOfStock)
            {
                <div class="out-of-stock-label">HẾT HÀNG</div>
            }
            <img src="@(string.IsNullOrEmpty(Model.Hinh_Anh) ? "/images/placeholder.png" : Model.Hinh_Anh)"
                 class="product-card-img" alt="@Model.Ten_San_Pham">
        </div>

        <div class="card-body p-3 d-flex flex-column flex-grow-1">
            <p class="text-muted small mb-1">@Model.SubCategory?.Ten_Danh_Muc_Con</p>
            <h6 class="fw-bold mb-2 text-dark" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 38px;">
                @Model.Ten_San_Pham
            </h6>

            <div class="mt-auto">
                <div class="d-flex align-items-center gap-2 mb-3">
                    @if (totalDiscountPercent > 0)
                    {
                        <span class="price-current">@finalPrice.ToString("C0", culture)</span>
                        <span class="price-original">@Model.Gia_Goc.ToString("C0", culture)</span>
                    }
                    else
                    {
                        <span class="price-current">@Model.Gia_Goc.ToString("C0", culture)</span>
                    }
                </div>
            </div>
        </div>
    </a>
    
    <!-- Footer with quantity and add to cart, placed outside <a> so they can be clicked independently without triggering navigation -->
    <div class="px-3 pb-3 mt-auto">
        <div class="d-flex align-items-center justify-content-between border-top pt-3">
            <div class="quantity-selector">
                <button class="quantity-btn btn-minus" type="button" @(isOutOfStock ? "disabled" : "") onclick="updateQty(this, -1)">-</button>
                <input type="number" class="quantity-input" value="1" min="1" max="@effectiveStock" @(isOutOfStock ? "disabled" : "") readonly>
                <button class="quantity-btn btn-plus" type="button" @(isOutOfStock ? "disabled" : "") onclick="updateQty(this, 1)">+</button>
            </div>

            <button class="btn btn-danger rounded-pill px-3 py-2 btn-add-cart"
                    type="button"
                    style="background-color: @(isOutOfStock ? "#ccc" : "#0056b3"); border: none;"
                    @(isOutOfStock ? "disabled" : "")
                    onclick="addToCart('@Model.Product_ID', this)">
                <i class="fas fa-cart-plus"></i>
            </button>
        </div>
    </div>
</div>

<script>
    window.updateQty = function (btn, delta) {
        const input = btn.parentElement.querySelector('.quantity-input');
        let val = parseInt(input.value || '1', 10) + delta;
        val = Math.max(1, Math.min(val, parseInt(input.max || '999', 10)));
        input.value = val;
    };

    window.showToast = function (message, type = 'success') {
        const container = document.getElementById('toast-container');
        if (!container) {
            return;
        }

        const toast = document.createElement('div');
        toast.className = 'toast-custom';
        toast.innerHTML = `
            <i class="fas ${type === 'success' ? 'fa-check-circle text-success' : 'fa-exclamation-circle text-danger'} fa-lg"></i>
            <div>${message}</div>
        `;
        container.appendChild(toast);
        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateY(-20px)';
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    };

    window.showCartModal = function (message, suggestions = []) {
        const existingModal = document.getElementById('cartActionModal');
        if (existingModal) {
            existingModal.remove();
        }

        let suggestionsHtml = '';
        if (suggestions && suggestions.length > 0) {
            suggestionsHtml = `
                <div class="mt-4 pt-3 border-top">
                    <p class="fw-bold mb-2 text-start small text-uppercase text-muted" style="letter-spacing: 0.5px; font-size: 0.7rem;">Sản phẩm gợi ý cho bạn</p>
                    <div class="row g-2">
                        ${suggestions.map(item => {
                            const priceText = new Intl.NumberFormat('vi-VN').format(item.price) + '₫';
                            return `
                            <div class="col-4">
                                <div class="card h-100 border-0 shadow-sm p-1 text-center" style="background: #f8fafc; border-radius: 10px;">
                                    <a href="/Home/Details/${item.id}" class="text-decoration-none text-dark">
                                        <img src="${item.image}" class="img-fluid rounded mb-1" alt="${item.name}" style="height: 45px; width: 100%; object-fit: cover;">
                                        <p class="mb-1 fw-bold text-truncate" style="font-size: 0.65rem;" title="${item.name}">${item.name}</p>
                                        <div class="fw-bold text-danger" style="font-size: 0.7rem;">${priceText}</div>
                                    </a>
                                    <button class="btn btn-sm btn-success mt-1 rounded-pill py-0 w-100" onclick="window.addSuggestedItem(${item.id}, this)" style="font-size: 0.6rem;">Thêm</button>
                                </div>
                            </div>`;
                        }).join('')}
                    </div>
                </div>`;
        }

        const modal = document.createElement('div');
        modal.className = 'modal fade';
        modal.id = 'cartActionModal';
        modal.tabIndex = -1;
        modal.innerHTML = `
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg rounded-4">
                    <div class="modal-body p-4 text-center">
                        <div class="mb-3">
                            <i class="fas fa-shopping-bag fa-2x text-success"></i>
                        </div>
                        <h5 class="fw-bold mb-1" style="font-size: 1.1rem;">Đã cập nhật giỏ hàng</h5>
                        <p class="text-muted mb-3 small">${message}</p>
                        <div class="d-flex justify-content-center gap-2">
                            <button type="button" class="btn btn-outline-secondary btn-sm rounded-pill px-3" data-bs-dismiss="modal">Tiếp tục mua</button>
                            <a href="/Cart" class="btn btn-success btn-sm rounded-pill px-3">Đến giỏ hàng</a>
                        </div>
                        ${suggestionsHtml}
                    </div>
                </div>
            </div>
        `;

        document.body.appendChild(modal);
        const modalInstance = new bootstrap.Modal(modal);
        modalInstance.show();
        modal.addEventListener('hidden.bs.modal', () => modal.remove());
    };

    window.addToCart = async function (id, btn) {
        const isAuthenticated = @(User.Identity?.IsAuthenticated == true ? "true" : "false");
        if (!isAuthenticated) {
            const returnUrl = encodeURIComponent('/Cart/Index');
            window.location.href = `/Account/Login?ReturnUrl=${returnUrl}`;
            return;
        }

        const qtyInput = btn.closest('.product-card').querySelector('.quantity-input');
        const qty = qtyInput?.value || '1';

        try {
            const response = await fetch('/Cart/Add', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: new URLSearchParams({ id, quantity: qty })
            });

            const contentType = response.headers.get('content-type') || '';
            if (!contentType.includes('application/json')) {
                throw new Error('Phản hồi từ máy chủ không đúng định dạng JSON.');
            }

            const data = await response.json();
            if (!response.ok || !data.success) {
                throw new Error(data.message || 'Không thể thêm vào giỏ hàng.');
            }

            window.showToast(data.message, 'success');
            if (typeof window.refreshCartSummary === 'function') {
                window.refreshCartSummary(data.summary);
            }

            btn.style.transform = 'scale(0.8)';
            setTimeout(() => btn.style.transform = 'scale(1)', 100);
            window.showCartModal(data.message, data.suggestions);
        } catch (error) {
            window.showToast(error.message || 'Không thể thêm vào giỏ hàng.', 'error');
        }
    };

    window.addSuggestedItem = async function(id, btn) {
        const originalText = btn.innerText;
        btn.disabled = true;
        btn.innerText = '...';
        
        try {
            const response = await fetch('/Cart/Add', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: new URLSearchParams({ id: id, quantity: 1 })
            });
            const data = await response.json();
            if (data.success) {
                btn.innerText = '✓';
                btn.classList.replace('btn-success', 'btn-outline-success');
                if (typeof window.refreshCartSummary === 'function') {
                    window.refreshCartSummary(data.summary);
                }
            } else {
                window.showToast(data.message, 'error');
                btn.disabled = false;
                btn.innerText = originalText;
            }
        } catch (err) {
            console.error(err);
            btn.disabled = false;
            btn.innerText = originalText;
        }
    };
</script>
