@model SubCategory
@{
    ViewData["Title"] = "Sửa danh mục con";
}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0" style="color:#2e59d9;">Sửa danh mục con</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
    </div>
    <div class="card border-0 shadow-sm" style="border-radius:12px;">
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="SubCategory_ID" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
                <div class="mb-3">
                    <label asp-for="Ten_Danh_Muc_Con" class="form-label">Tên danh mục con</label>
                    <input asp-for="Ten_Danh_Muc_Con" class="form-control" />
                    <span asp-validation-for="Ten_Danh_Muc_Con" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Category_ID" class="form-label">Danh mục chính</label>
                    <select asp-for="Category_ID" class="form-select">
                        @foreach (var c in (IEnumerable<Category>)ViewBag.Categories)
                        {
                            <option value="@c.Category_ID">@c.Ten_Danh_Muc</option>
                        }
                    </select>
                </div>
                <button type="submit" class="btn btn-primary px-4">Lưu thay đổi</button>
            </form>
        </div>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
