@model SubCategory
@{
    ViewData["Title"] = "Chi tiết danh mục con";
}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0" style="color:#2e59d9;">Chi tiết danh mục con</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
    </div>
    <div class="card border-0 shadow-sm" style="border-radius:12px;">
        <div class="card-body p-4">
            <p><strong>ID:</strong> #@Model.SubCategory_ID</p>
            <p><strong>Tên:</strong> @Model.Ten_Danh_Muc_Con</p>
            <p><strong>Danh mục chính:</strong> @Model.Category?.Ten_Danh_Muc</p>
            <p><strong>Số sản phẩm liên kết:</strong> @Model.Products.Count</p>
            <a asp-action="Edit" asp-route-id="@Model.SubCategory_ID" class="btn btn-primary">Sửa</a>
        </div>
    </div>
</div>
