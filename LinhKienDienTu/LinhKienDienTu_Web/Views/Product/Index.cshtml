@model IEnumerable<Product>

@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

@using System.Text.Json

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    :root {
        --primary-color: #4e73df;
        --secondary-color: #858796;
        --success-color: #1cc88a;
        --info-color: #36b9cc;
        --danger-color: #e74a3b;
        --border-radius-lg: 12px;
    }

    body {
        background-color: #f8f9fc;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }

    .main-card {
        border: none;
        border-radius: var(--border-radius-lg);
        box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.1);
        background: white;
    }

    .table thead th {
        background-color: #f8f9fa;
        color: #4e73df;
        font-size: 0.9rem; /* Tăng cỡ chữ tiêu đề */
        font-weight: 700;
        text-transform: uppercase;
        border-top: none;
        padding: 1.25rem;
    }

    .table tbody td {
        font-size: 1rem; /* Tăng cỡ chữ nội dung */
        vertical-align: middle;
        padding: 1.25rem;
        border-bottom: 1px solid #e3e6f0;
    }

    /* Hiệu ứng dòng khi di chuột */
    .table tbody tr:hover {
        background-color: #fdfdfd;
        transition: 0.2s;
    }

    .product-title {
        font-weight: 600;
        color: #2e59d9;
        font-size: 1.1rem;
    }

    .price-text {
        font-weight: 700;
        color: #e74a3b;
        font-size: 1.1rem;
    }

    /* Nút thêm mới kiểu E-commerce */
    .btn-add {
        background-color: var(--primary-color);
        color: white;
        padding: 12px 24px;
        border-radius: 10px;
        font-weight: 600;
        border: none;
        transition: all 0.3s;
    }

        .btn-add:hover {
            background-color: #2e59d9;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(78, 115, 223, 0.4);
            color: white;
        }

    /* Tạo hình cho các nút biểu tượng */
    .action-icons {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
    }

    .btn-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        border: none;
        text-decoration: none;
    }

    .btn-edit {
        background: #eef2ff;
        color: #4e73df;
    }

        .btn-edit:hover {
            background: #4e73df;
            color: white;
        }

    .btn-view {
        background: #e0fafb;
        color: #36b9cc;
    }

        .btn-view:hover {
            background: #36b9cc;
            color: white;
        }

    .btn-del {
        background: #fff1f0;
        color: #e74a3b;
    }

        .btn-del:hover {
            background: #e74a3b;
            color: white;
        }

    .badge-ecommerce {
        font-size: 0.85rem;
        padding: 8px 12px;
        border-radius: 6px;
    }
</style>

<div class="container py-5">
    @if (TempData["SuccessMessage"] is string successMessage && !string.IsNullOrWhiteSpace(successMessage))
    {
        <script>
            window.addEventListener('load', function () {
                alert(@Html.Raw(JsonSerializer.Serialize(successMessage)));
            });
        </script>
    }

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5">
        <div>
            <h1 class="h3 mb-1 text-gray-800 fw-bold">Danh Mục Sản Phẩm</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0">
                    <li class="breadcrumb-item"><a href="#">Hệ thống</a></li>
                    <li class="breadcrumb-item active">Sản phẩm</li>
                </ol>
            </nav>
        </div>
        <a asp-action="Create" class="btn btn-add shadow-sm">
            <i class="bi bi-plus-circle-fill me-2"></i> THÊM MỚI SẢN PHẨM
        </a>
    </div>

    <div class="main-card shadow">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th width="35%">Thông tin sản phẩm</th>
                        <th width="15%">Giá niêm yết</th>
                        <th width="15%" class="text-center">Kho hàng</th>
                        <th width="10%">Địa lý</th>
                        <th width="15%">Trạng thái</th>
                        <th width="20%" class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-light rounded p-2 me-3 d-none d-sm-block">
                                        @if (item.IsCombo)
                                        {
                                            <i class="bi bi-stack text-info" style="font-size: 1.5rem;"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-box-seam text-secondary" style="font-size: 1.5rem;"></i>
                                        }
                                    </div>
                                    <div>
                                        <div class="product-title">
                                            @item.Ten_San_Pham
                                            @if (item.IsCombo)
                                            {
                                                <span class="badge bg-info ms-1" style="font-size: 0.7rem;">COMBO</span>
                                            }
                                        </div>
                                        <small class="text-muted">ID: #@item.Product_ID</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="price-text">@item.Gia_Goc.ToString("N0") <small>đ</small></span>
                            </td>
                            <td class="text-center">
                                @{
                                    int effStock = item.So_Luong_Ton;
                                    if (item.IsCombo && item.ComboDetails != null && item.ComboDetails.Any())
                                    {
                                        effStock = int.MaxValue;
                                        foreach (var cd in item.ComboDetails)
                                        {
                                            if (cd.ComponentProduct != null)
                                            {
                                                int p = cd.ComponentProduct.So_Luong_Ton / cd.So_Luong_Thanh_Phan;
                                                if (p < effStock) effStock = p;
                                            }
                                        }
                                        if (effStock == int.MaxValue) effStock = 0;
                                    }
                                }
                                <span class="badge bg-light text-dark border p-2">
                                    <strong>@effStock</strong> @(item.IsCombo ? "combo" : "cái")
                                </span>
                            </td>
                            <td>
                                @if (item.IsTphcmOnly)
                                {
                                    <span class="badge bg-danger rounded-pill small" style="font-size: 0.65rem;">TP.HCM ONLY</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-muted border rounded-pill small" style="font-size: 0.65rem;">TOÀN QUỐC</span>
                                }
                            </td>
                            <td>
                                @if (effStock > 10)
                                {
                                    <span class="badge bg-success-subtle text-success badge-ecommerce">
                                        <i class="bi bi-check2-all"></i> Còn hàng
                                    </span>
                                }
                                else if (effStock > 0)
                                {
                                    <span class="badge bg-warning-subtle text-warning badge-ecommerce">
                                        <i class="bi bi-exclamation-triangle"></i> Sắp hết
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger badge-ecommerce">
                                        <i class="bi bi-slash-circle"></i> Hết hàng
                                    </span>
                                }
                            </td>
                            <td>
                                <div class="action-icons">
                                    <a asp-action="Edit" asp-route-id="@item.Product_ID"
                                       class="btn-circle btn-edit" title="Chỉnh sửa">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Product_ID"
                                       class="btn-circle btn-view" title="Chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Product_ID"
                                       class="btn-circle btn-del" title="Xóa sản phẩm">
                                        <i class="bi bi-trash3"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-white border-top py-3">
            <div class="row align-items-center">
                <div class="col-sm-6 text-muted small">
                    Hiển thị 1 - @Model.Count() sản phẩm
                </div>
                <div class="col-sm-6 text-end">
                    <small class="text-muted">Cập nhật lúc: @DateTime.Now.ToString("HH:mm")</small>
                </div>
            </div>
        </div>
    </div>
</div>