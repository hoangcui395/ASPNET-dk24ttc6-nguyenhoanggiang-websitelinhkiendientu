@model Product

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<style>
    .main-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.1);
        background: white;
    }

    .page-title {
        color: #2e59d9;
        font-weight: 800;
    }

    .label-title {
        color: #858796;
        font-size: 0.9rem;
        margin-bottom: 0.25rem;
    }

    .value-text {
        font-weight: 600;
        color: #2e2f37;
    }

    .img-product {
        width: 100%;
        max-height: 260px;
        object-fit: cover;
        border-radius: 12px;
    }

    .stat-chip {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        font-weight: 700;
        font-size: 0.9rem;
    }
</style>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="page-title mb-1">Chi tiết sản phẩm</h2>
            <div class="text-muted">Mã sản phẩm: <strong>#@Model.Product_ID</strong></div>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Quay lại danh sách</a>
    </div>

    <div class="main-card p-4">
        <div class="row">
            <div class="col-lg-4 mb-3">
                @if (!string.IsNullOrWhiteSpace(Model.Hinh_Anh))
                {
                    <img src="@Model.Hinh_Anh" alt="Ảnh sản phẩm" class="img-product border" />
                }
                else
                {
                    <div class="rounded border d-flex align-items-center justify-content-center bg-light" style="height:260px;border-radius:12px;">
                        <span class="text-muted">Không có ảnh</span>
                    </div>
                }
            </div>
            <div class="col-lg-8">
                <div class="d-flex flex-wrap gap-2 mb-3">
                    @{
                        int effectiveStock = Model.So_Luong_Ton;
                        if (Model.IsCombo && Model.ComboDetails != null && Model.ComboDetails.Any())
                        {
                            effectiveStock = int.MaxValue;
                            foreach (var item in Model.ComboDetails)
                            {
                                if (item.ComponentProduct != null)
                                {
                                    int possible = item.ComponentProduct.So_Luong_Ton / item.So_Luong_Thanh_Phan;
                                    if (possible < effectiveStock) effectiveStock = possible;
                                }
                            }
                            if (effectiveStock == int.MaxValue) effectiveStock = 0;
                        }
                    }

                    @if (effectiveStock > 10)
                    {
                        <span class="stat-chip" style="background:#d1fae5;color:#065f46;">Còn hàng</span>
                    }
                    else if (effectiveStock > 0)
                    {
                        <span class="stat-chip" style="background:#fef3c7;color:#92400e;">Sắp hết</span>
                    }
                    else
                    {
                        <span class="stat-chip" style="background:#fee2e2;color:#991b1b;">Hết hàng</span>
                    }
                    <span class="stat-chip" style="background:#eef2ff;color:#2e59d9;">
                        @(Model.IsCombo ? "Tồn kho Combo (tính động):" : "Kho:") @effectiveStock
                    </span>
                    @if (Model.IsCombo)
                    {
                        <span class="stat-chip bg-info text-white">SẢN PHẨM COMBO</span>
                    }
                </div>

                <div class="row">
                    <div class="col-12 mb-3">
                        <div class="label-title">Tên sản phẩm</div>
                        <div class="value-text" style="font-size:1.1rem;">@Model.Ten_San_Pham</div>
                    </div>
                    
                    @if (Model.IsCombo && Model.ComboDetails != null && Model.ComboDetails.Any())
                    {
                        <div class="col-12 mb-4">
                            <div class="alert alert-info py-2 px-3 border-0 rounded-4">
                                <h6 class="fw-bold mb-2"><i class="fas fa-list-ul me-2"></i>Thành phần gồm:</h6>
                                <ul class="list-unstyled mb-0">
                                    @foreach (var item in Model.ComboDetails)
                                    {
                                        <li class="mb-1">
                                            <i class="bi bi-check2-circle text-success me-1"></i>
                                            <strong>@item.So_Luong_Thanh_Phan x</strong> 
                                            <a href="@Url.Action("Details", new { id = item.Product_ID })" class="text-decoration-none">
                                                @item.ComponentProduct?.Ten_San_Pham
                                            </a>
                                            <small class="text-muted ms-1">(Kho hiện có: @item.ComponentProduct?.So_Luong_Ton)</small>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                    }

                    <div class="col-md-6 mb-3">
                        <div class="label-title">Giá thực tế (Gốc: @Model.Gia_Goc.ToString("N0") đ)</div>
                        <div class="value-text text-danger" style="font-size:1.15rem;">
                            @{
                                var now = DateTime.Now;
                                bool hasActivePromotion = Model.Promotion != null && 
                                    Model.Promotion.Ngay_Bat_Dau <= now && 
                                    Model.Promotion.Ngay_Ket_Thuc >= now;
                                    
                                decimal totalDiscountPercent = hasActivePromotion ? Model.Promotion.Phan_Tram_Giam : Model.Phan_Tram_Giam;
                                totalDiscountPercent = Math.Min(totalDiscountPercent, 100m);
                                decimal finalPrice = Model.Gia_Goc * (1 - totalDiscountPercent / 100);
                            }
                            @finalPrice.ToString("N0") đ
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="label-title">Trạng thái (nhập tay)</div>
                        <div class="value-text">@Model.Trang_Thai</div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="label-title">Danh mục con</div>
                        <div class="value-text">
                            @(Model.SubCategory?.Ten_Danh_Muc_Con ?? $"#{Model.SubCategory_ID}")
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="label-title">Đang áp dụng Khuyến mãi</div>
                        <div class="value-text text-success fw-bold">-@totalDiscountPercent %</div>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-2">
                    <a asp-action="Edit" asp-route-id="@Model.Product_ID" class="btn btn-primary px-4">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@Model.Product_ID" class="btn btn-outline-danger px-4">Xóa</a>
                    <a asp-action="Index" class="btn btn-light border px-4">Đóng</a>
                </div>
            </div>
        </div>
    </div>
</div>