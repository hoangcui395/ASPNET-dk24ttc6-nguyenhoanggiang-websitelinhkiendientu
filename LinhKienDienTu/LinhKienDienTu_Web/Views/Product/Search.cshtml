@model IEnumerable<LinhKienDienTu_Web.Models.Product>
@{
    ViewData["Title"] = "Kết quả tìm kiếm";
    var keyword = ViewBag.Keyword as string;
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: #0056b3; font-weight: bold;">
            Kết quả tìm kiếm cho: "@keyword"
        </h2>
        <span class="text-muted">Tìm thấy @Model.Count() sản phẩm</span>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info py-4 border-0 shadow-sm text-center rounded-3">
            <i class="fas fa-search fa-3x mb-3 text-muted"></i>
            <h5>Không tìm thấy sản phẩm nào phù hợp với từ khóa của bạn.</h5>
            <p class="mb-0">Vui lòng thử lại với từ khóa khác!</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <partial name="_ProductCard" model="item" />
                </div>
            }
        </div>
    }
</div>

<style>
    .product-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
    .product-card:hover .product-image {
        transform: scale(1.05);
    }
    .title-hover:hover {
        color: #0056b3 !important;
    }
    .btn-add-cart {
        transition: background-color 0.3s ease;
    }
    .btn-add-cart:hover {
        background-color: #55aa00 !important;
    }
</style>
