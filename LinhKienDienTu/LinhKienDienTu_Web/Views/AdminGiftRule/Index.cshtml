@model IEnumerable<LinhKienDienTu_Web.Models.GiftRule>
@{
    ViewData["Title"] = "Quy tắc quà tặng";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="fas fa-gift me-2 text-danger"></i>Quy tắc quà tặng</h2>
        <a asp-action="Create" class="btn btn-danger rounded-pill px-4 shadow-sm border-0" style="background: linear-gradient(135deg, #ff416c 0%, #ff4b2b 100%);">
            <i class="fas fa-plus me-2"></i>Thêm quy tắc
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-4 mb-4">@TempData["SuccessMessage"]</div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light small text-uppercase fw-bold text-muted">
                <tr>
                    <th class="ps-4">Sản phẩm chính</th>
                    <th>Số lượng tối thiểu</th>
                    <th>Sản phẩm tặng</th>
                    <th>Trạng thái</th>
                    <th class="text-end pe-4">Xóa</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <img src="@item.MainProduct?.Hinh_Anh" style="width:40px; height:40px; object-fit:contain;" class="me-2" />
                                <span class="fw-semibold">@item.MainProduct?.Ten_San_Pham</span>
                            </div>
                        </td>
                        <td>Mua từ <span class="badge bg-primary rounded-pill px-3">@item.MinQuantity</span> sản phẩm</td>
                        <td>
                            <div class="d-flex align-items-center text-success fw-bold">
                                <i class="fas fa-gift me-2"></i>
                                <span>@item.GiftProduct?.Ten_San_Pham</span>
                            </div>
                        </td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success-subtle text-success rounded-pill px-3">Đang chạy</span>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <button onclick="deleteRule(@item.GiftRule_ID)" class="btn btn-sm btn-outline-danger border-0 rounded-circle">
                                <i class="fas fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function deleteRule(id) {
            if (confirm("Xóa quy tắc này?")) {
                $.post("/AdminGiftRule/Delete/" + id, function (res) {
                    if (res.success) location.reload();
                });
            }
        }
    </script>
}
