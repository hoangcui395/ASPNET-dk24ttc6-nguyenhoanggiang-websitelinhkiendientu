@model IEnumerable<LinhKienDienTu_Web.Models.ChatSession>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Quản lý Chat Trực tuyến";
}

<div class="container-fluid mt-4">
    <div class="row">
        <!-- Sidebar: Danh sách chat -->
        <div class="col-md-4 border-end">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-success text-white py-3">
                    <h5 class="mb-0"><i class="fas fa-comments me-2"></i>Phiên hỗ trợ đang chờ</h5>
                </div>
                <div class="list-group list-group-flush" id="sessionList" style="max-height: 70vh; overflow-y: auto;">
                    @foreach (var session in Model)
                    {
                        <a href="javascript:void(0)" 
                           class="list-group-item list-group-item-action p-3 @(session == Model.First() ? "active" : "")"
                           onclick="loadSession('@session.SessionId', this)">
                            <div class="d-flex justify-content-between align-items-center">
                                <strong class="text-truncate">@session.GuestOrUserId</strong>
                                <small>@session.CreatedAt.ToString("HH:mm")</small>
                            </div>
                            <p class="mb-0 small text-muted text-truncate last-msg">
                                @(session.Messages.LastOrDefault()?.Content ?? "Bắt đầu hội thoại")
                            </p>
                        </a>
                    }
                    @if (!Model.Any())
                    {
                        <div class="p-5 text-center text-muted">
                            <i class="fas fa-inbox fa-3x mb-3 opacity-25"></i>
                            <p>Không có yêu cầu hỗ trợ nào</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Chat Window -->
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden d-flex flex-column" style="height: 80vh;">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0 fw-bold" id="activeUserName">Chọn một hội thoại</h6>
                        <small class="text-success" id="activeStatus"></small>
                    </div>
                </div>

                <div class="card-body p-3 bg-light" id="adminMessages" style="flex-grow: 1; overflow-y: auto;">
                    <div class="text-center mt-5 text-muted">
                        Hãy chọn khách hàng từ danh sách bên trái để bắt đầu hỗ trợ.
                    </div>
                </div>

                <div class="card-footer bg-white border-top p-3 d-none" id="adminChatInputSection">
                    <div class="input-group">
                        <input type="text" id="adminChatInput" class="form-control rounded-pill border-0 bg-light px-4" placeholder="Nhập câu trả lời..." onkeypress="handleKeyPress(event)">
                        <button class="btn btn-success rounded-circle ms-2" onclick="sendAdminMessage()">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        let currentSessionId = '';
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chathub")
            .build();

        connection.on("ReceiveMessage", function (sessionId, sender, message) {
            if (sessionId === currentSessionId) {
                addMessage(sender, message);
            }
            // Update last message in sidebar
            $(`a[onclick*='${sessionId}'] .last-msg`).text(message);
        });

        connection.start().then(() => {
            connection.invoke("JoinAdminGroup");
        });

        function loadSession(id, el) {
            currentSessionId = id;
            $('#activeUserName').text($(el).find('strong').text());
            $('#activeStatus').text('Đang trực tuyến');
            $('#sessionList a').removeClass('active');
            $(el).addClass('active');
            $('#adminChatInputSection').removeClass('d-none');

            // Load messages
            $.get('/AdminChat/GetMessages', { sessionId: id }, function (data) {
                let html = '';
                data.forEach(m => {
                    html += createMessageHtml(m.sender, m.content);
                });
                $('#adminMessages').html(html);
                scrollToBottom();
            });
        }

        function createMessageHtml(sender, content) {
            const isMe = (sender === 'Admin');
            return `
                <div class="d-flex mb-3 ${isMe ? 'justify-content-end' : 'justify-content-start'}">
                    <div class="p-3 rounded-4 shadow-sm ${isMe ? 'bg-success text-white' : 'bg-white'}" style="max-width: 80%;">
                        <div class="small fw-bold mb-1">${sender}</div>
                        <div>${content}</div>
                    </div>
                </div>
            `;
        }

        function addMessage(sender, content) {
            $('#adminMessages').append(createMessageHtml(sender, content));
            scrollToBottom();
        }

        function handleKeyPress(e) {
            if (e.key === 'Enter') sendAdminMessage();
        }

        function sendAdminMessage() {
            const input = $('#adminChatInput');
            const message = input.val().trim();
            if (!message || !currentSessionId) return;

            connection.invoke("AdminSendMessage", currentSessionId, message).catch(err => console.error(err));
            addMessage('Admin', message);
            input.val('');
        }

        function scrollToBottom() {
            const msgBody = document.getElementById('adminMessages');
            msgBody.scrollTop = msgBody.scrollHeight;
        }
    </script>
}

<style>
    .rounded-4 { border-radius: 1rem !important; }
</style>
