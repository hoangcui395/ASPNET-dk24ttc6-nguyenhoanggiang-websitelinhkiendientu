@model Category

@{
    ViewData["Title"] = "Chi tiết danh mục";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1 fw-bold" style="color:#2e59d9;">Chi tiết danh mục</h2>
            <small class="text-muted">Mã danh mục: #@Model.Category_ID</small>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Quay lại danh sách</a>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius:12px;">
        <div class="card-body p-4">
            <div class="mb-3">
                <div class="text-muted small">Tên danh mục</div>
                <div class="fw-semibold fs-5">@Model.Ten_Danh_Muc</div>
            </div>

            <div class="mb-3">
                <div class="text-muted small">Số danh mục con</div>
                <span class="badge bg-light text-dark border fs-6">@Model.SubCategories.Count</span>
            </div>

            @if (Model.SubCategories.Any())
            {
                <div class="mt-3">
                    <div class="text-muted small mb-2">Danh mục con liên kết</div>
                    <ul class="list-group">
                        @foreach (var sub in Model.SubCategories)
                        {
                            <li class="list-group-item">@sub.Ten_Danh_Muc_Con</li>
                        }
                    </ul>
                </div>
            }

            <div class="mt-4">
                <a asp-action="Edit" asp-route-id="@Model.Category_ID" class="btn btn-primary px-4">Sửa</a>
                <a asp-action="Delete" asp-route-id="@Model.Category_ID" class="btn btn-outline-danger px-4 ms-2">Xóa</a>
            </div>
        </div>
    </div>
</div>