@model Category

@{
    ViewData["Title"] = "Xóa danh mục";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0 fw-bold" style="color:#e74a3b;">Xóa danh mục</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Quay lại danh sách</a>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius:12px;">
        <div class="card-body p-4">
            <div class="alert alert-danger">
                Bạn có chắc muốn xóa danh mục <strong>@Model.Ten_Danh_Muc</strong>?
            </div>
            <div class="mb-3">
                <div><strong>ID:</strong> #@Model.Category_ID</div>
                <div><strong>Số danh mục con:</strong> @Model.SubCategories.Count</div>
            </div>

            @if (Model.SubCategories.Any())
            {
                <div class="alert alert-warning">
                    Danh mục này đang có danh mục con liên kết, hệ thống sẽ không cho phép xóa.
                </div>
            }

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Category_ID" />
                <button type="submit" class="btn btn-danger px-4" @(Model.SubCategories.Any() ? "disabled" : null)>Xóa</button>
                <a asp-action="Index" class="btn btn-light border ms-2">Hủy</a>
            </form>
        </div>
    </div>
</div>