@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <i class="fas fa-key fa-3x text-success mb-3"></i>
                        <h3 class="fw-bold">Khôi phục mật khẩu</h3>
                        <p class="text-muted">Nhập email của bạn để nhận liên kết khôi phục</p>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger rounded-3"><i class="fas fa-exclamation-circle me-1"></i>@ViewBag.Error</div>
                    }

                    @if (ViewBag.Message != null)
                    {
                        <div class="alert alert-success rounded-3"><i class="fas fa-check-circle me-1"></i>@ViewBag.Message</div>
                    }

                    @if (ViewBag.MockLink != null)
                    {
                        <div class="alert alert-warning mt-3 rounded-3" style="word-break: break-all;">
                            <strong>(Dev Mode) Link khôi phục:</strong> <br />
                            <a href="@ViewBag.MockLink">Nhấn vào đây để đặt lại mật khẩu</a>
                        </div>
                    }

                    <form asp-action="ForgotPassword" method="post">
                        <div class="form-floating mb-4">
                            <input type="email" class="form-control rounded-3" id="email" name="email" placeholder="name@example.com" required>
                            <label for="email">Địa chỉ Email</label>
                        </div>

                        <button type="submit" class="btn btn-success w-100 rounded-pill py-3 fw-bold mb-3">Gửi liên kết khôi phục</button>
                        
                        <div class="text-center mt-3">
                            <a asp-action="Login" class="text-success text-decoration-none fw-semibold"><i class="fas fa-arrow-left me-1"></i>Quay lại đăng nhập</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
