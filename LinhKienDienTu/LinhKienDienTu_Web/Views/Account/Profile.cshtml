@model LinhKienDienTu_Web.Models.User
@{
    ViewData["Title"] = "Hồ sơ của tôi";
}

<div class="container py-5">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="fw-bold mb-1">Hồ sơ cá nhân</h1>
            <p class="text-muted">Quản lý thông tin bảo mật và tài khoản của bạn</p>
        </div>
    </div>

    @if (TempData["Success"] is string successMsg)
    {
        <div class="alert alert-success rounded-3 mb-4"><i class="fas fa-check-circle me-1"></i>@successMsg</div>
    }
    @if (TempData["Error"] is string errorMsg)
    {
        <div class="alert alert-danger rounded-3 mb-4"><i class="fas fa-exclamation-circle me-1"></i>@errorMsg</div>
    }

    @if (TempData["SuccessPwd"] is string successPwd)
    {
        <div class="alert alert-success rounded-3 mb-4"><i class="fas fa-check-circle me-1"></i>@successPwd</div>
    }
    @if (TempData["ErrorPwd"] is string errorPwd)
    {
        <div class="alert alert-danger rounded-3 mb-4"><i class="fas fa-exclamation-circle me-1"></i>@errorPwd</div>
    }

    <div class="row g-4">
        <!-- Thông tin hồ sơ -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 p-md-5">
                    <h5 class="fw-bold mb-4 border-bottom pb-3"><i class="fas fa-user-circle text-success me-2"></i>Cập nhật thông tin</h5>
                    
                    <form asp-action="Profile" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-semibold text-muted">Email đăng nhập (Không thể thay đổi)</label>
                            <input type="email" class="form-control rounded-3" value="@Model.Email" disabled readonly>
                        </div>

                        <div class="mb-3">
                            <label for="hoTen" class="form-label fw-semibold">Họ và tên</label>
                            <input type="text" class="form-control rounded-3" id="hoTen" name="hoTen" value="@Model.Ho_Ten" required>
                        </div>
                        
                        <div class="mb-4">
                            <label for="soDienThoai" class="form-label fw-semibold">Số điện thoại</label>
                            <input type="text" class="form-control rounded-3" id="soDienThoai" name="soDienThoai" value="@Model.So_Dien_Thoai" required>
                        </div>

                        <button type="submit" class="btn btn-success rounded-pill px-4 fw-bold">Lưu thay đổi</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Đổi mật khẩu -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 p-md-5">
                    <h5 class="fw-bold mb-4 border-bottom pb-3"><i class="fas fa-lock text-success me-2"></i>Đổi mật khẩu</h5>
                    
                    <form asp-action="ChangePassword" method="post">
                        <div class="mb-3">
                            <label for="oldPassword" class="form-label fw-semibold">Mật khẩu hiện tại</label>
                            <input type="password" class="form-control rounded-3" id="oldPassword" name="oldPassword" required>
                        </div>
                        
                        <div class="mb-3">
                            <label for="newPassword" class="form-label fw-semibold">Mật khẩu mới</label>
                            <input type="password" class="form-control rounded-3" id="newPassword" name="newPassword" required minlength="6">
                        </div>

                        <div class="mb-4">
                            <label for="confirmPassword" class="form-label fw-semibold">Xác nhận mật khẩu mới</label>
                            <input type="password" class="form-control rounded-3" id="confirmPassword" name="confirmPassword" required minlength="6">
                        </div>

                        <button type="submit" class="btn btn-warning text-dark rounded-pill px-4 fw-bold">Đổi mật khẩu</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
